#include<stdio.h>
int main()
{
	char op;
	double num1,num2,result;
	printf("BASIC CALCULATOR\n");
	printf("Enter the operator:\n");
	scanf("%c",&op);
	printf("Enter first number:\n");
	scanf("%lf",&num1);
	printf("Enter second number:\n");
	scanf("%lf",&num2);
	switch(op)
	{
		case'+':
			result=num1+num2;
			printf("%lf",result);
			break;
			case'-':
				result=num1-num2;
				printf("%lf",result);
				break;
				case'*':
					result=num1*num2;
					printf("%lf",result);
					break;
					case'/':
						if(num2 == 0)
						{
							printf("Error");
						}
						else
						{
							result=num1/num2;
							printf("%lf",result);
						}
						break;
						default:
							printf("Invalid Operator");
	}
	return 0;
	}
